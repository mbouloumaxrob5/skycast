# Configuration pour SkyCast
# Copiez ce fichier vers .env.local et remplacez les valeurs

# Clé API OpenWeatherMap (obligatoire)
# Obtenez une clé gratuite sur : https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_API_KEY=votre_cle_api_ici

# URL de base de l'API (optionnel, valeur par défaut recommandée)
# NEXT_PUBLIC_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Mode de développement (optionnel)
# NODE_ENV=development
